{
  "version": 2,
  "rewrites": [
    {
      "source": "/users/:path*",
      "destination": "/api"
    },
    {
      "source": "/tasks/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|users|tasks|assets|images|favicon.ico|index.html).*)",
      "destination": "/index.html"
    }
  ]
}
